# ── Required ───────────────────────────────────────────────────────────────────
# Claude Haiku — lead agent reasoning, task analysis, REGIS governance
ANTHROPIC_API_KEY=sk-ant-...

# ── Strongly recommended ───────────────────────────────────────────────────────
# DeepSeek Chat — support agents (~80% cheaper than Claude)
DEEPSEEK_API_KEY=sk-...

# PocketBase — database (local or Railway deployed)
POCKETBASE_URL=http://localhost:8090

# ── Optional — activates real agent tools ─────────────────────────────────────
# E2B Python sandbox — CIPHER code execution, FORGE file write
E2B_API_KEY=e2b_...

# Firecrawl — ATLAS web search with real source URLs
FIRECRAWL_API_KEY=fc-...

# MoonPay — fiat→SOL onramp widget (omit for sandbox mode)
MOONPAY_API_KEY=pk_...

# ── Telegram Bot ───────────────────────────────────────────────────────────────
# Create at https://t.me/BotFather
TELEGRAM_BOT_TOKEN=...
# Your Telegram chat ID (send /start to @userinfobot to find yours)
TELEGRAM_CHAT_ID=...

# ── Solana ─────────────────────────────────────────────────────────────────────
# Defaults to public Solana devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# ── Execution mode ─────────────────────────────────────────────────────────────
# "false" = mock wallets and signatures (safe demo)
# "true"  = real Solana devnet transactions (balances will change)
LIVE_MODE=false

# ── Security ───────────────────────────────────────────────────────────────────
# Required to toggle LIVE_MODE via POST /mode/toggle
ADMIN_API_KEY=change-me-before-production

# Comma-separated allowed CORS origins (leave blank to allow all in dev)
ALLOWED_ORIGINS=http://localhost:3000

# ── Deployment ─────────────────────────────────────────────────────────────────
# Set to "production" on Railway — hides /docs, enables strict error handling
ENVIRONMENT=development

# Public URL of this backend service (used by Telegram bot self-calls)
BACKEND_URL=http://localhost:8000
